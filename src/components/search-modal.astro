---
import { Icon } from 'astro-icon/components'
---

<>
  <button
    type="button"
    id="search-open"
    class="text-muted-foreground hover:text-foreground hover:bg-muted -my-2 -me-2 inline-flex size-8 items-center justify-center rounded-md transition-colors cursor-pointer"
    aria-haspopup="dialog"
    aria-controls="search-modal"
    aria-label="Open search"
    title="Search (⌘K)"
  >
    <Icon name="lucide:search" class="size-4" />
    <span class="sr-only">Open search</span>
  </button>

  <div
    id="search-modal"
    class="fixed inset-0 z-100 hidden h-dvh w-screen"
    role="dialog"
    aria-modal="true"
    aria-labelledby="search-modal-title"
  >
    <button
      type="button"
      id="search-backdrop"
      class="bg-background/70 absolute inset-0 h-full w-full backdrop-blur-sm"
      aria-label="Close search"
    ></button>

    <div class="relative flex min-h-full w-full items-start justify-center p-4 pt-[10vh]">
      <div
        id="search-panel"
        class="bg-background border-border w-[min(44rem,100%)] rounded-xl border shadow-xl"
      >
        <div class="flex items-center gap-2 border-b px-3 py-2">
          <Icon name="lucide:search" class="text-muted-foreground size-4" />
          <input
            id="search-input"
            type="search"
            class="placeholder:text-muted-foreground h-9 w-full bg-transparent text-sm outline-none"
            placeholder="Search notes, projects, and pages..."
            autocomplete="off"
          />
          <button
            type="button"
            id="search-close"
            class="text-muted-foreground hover:text-foreground hover:cursor-pointer rounded-md p-1"
            aria-label="Close search"
          >
            <Icon name="lucide:x" class="size-4" />
          </button>
        </div>

        <div class="max-h-[60vh] overflow-auto px-3 pt-2 pb-4">
          <p id="search-status" class="text-muted-foreground px-1 py-2 text-sm">
            Type at least 2 characters.
          </p>
          <ul id="search-results" class="space-y-2"></ul>
        </div>
      </div>
    </div>
  </div>

  <div id="search-result-type-templates" class="hidden" aria-hidden="true">
    <span
      data-search-type="note"
      class="bg-muted text-muted-foreground inline-flex items-center gap-1.5 rounded-full border px-2 py-0.5 text-[11px]"
    >
      <Icon name="lucide:notebook-text" class="size-3" />
      Note
    </span>
    <span
      data-search-type="project"
      class="bg-muted text-muted-foreground inline-flex items-center gap-1.5 rounded-full border px-2 py-0.5 text-[11px]"
    >
      <Icon name="lucide:folder-kanban" class="size-3" />
      Project
    </span>
    <span
      data-search-type="page"
      class="bg-muted text-muted-foreground inline-flex items-center gap-1.5 rounded-full border px-2 py-0.5 text-[11px]"
    >
      <Icon name="lucide:file-text" class="size-3" />
      Page
    </span>
  </div>
</>

<script type="module">
  const MODAL_OPEN_CLASS = 'overflow-hidden'

  const initSearchModal = () => {
    const modal = document.getElementById('search-modal')
    if (!modal || modal.dataset.bound === 'true') return

    // Move modal out of sticky header context so fixed positioning covers the full viewport.
    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal)
    }

    const openButton = document.getElementById('search-open')
    const closeButton = document.getElementById('search-close')
    const backdrop = document.getElementById('search-backdrop')
    const panel = document.getElementById('search-panel')
    const input = document.getElementById('search-input')
    const status = document.getElementById('search-status')
    const resultsRoot = document.getElementById('search-results')
    const typeTemplatesRoot = document.getElementById(
      'search-result-type-templates',
    )

    let pagefind = null
    let debounceTimer = null

    const ignoredPathPrefixes = ['/tags', '/tags/', '/authors/']
    const ignoredExactPaths = new Set(['/', '/about', '/about/'])

    modal.dataset.bound = 'true'

    const setStatus = (message) => {
      if (status) status.textContent = message
    }

    const clearResults = () => {
      if (resultsRoot) resultsRoot.innerHTML = ''
    }

    const openModal = () => {
      modal.classList.remove('hidden')
      document.body.classList.add(MODAL_OPEN_CLASS)
      setTimeout(() => input?.focus(), 0)
    }

    const closeModal = () => {
      modal.classList.add('hidden')
      document.body.classList.remove(MODAL_OPEN_CLASS)
      openButton?.focus()
    }

    const loadPagefind = async () => {
      if (pagefind) return pagefind
      const module = await import('/pagefind/pagefind.js')
      pagefind = module.default ?? module
      return pagefind
    }

    const shouldIgnoreResultUrl = (url) => {
      try {
        const parsed = new URL(url, window.location.origin)
        const pathname = parsed.pathname
        if (ignoredExactPaths.has(pathname)) return true
        return ignoredPathPrefixes.some((prefix) => pathname.startsWith(prefix))
      } catch {
        return false
      }
    }

    const getResultType = (url) => {
      try {
        const { pathname } = new URL(url, window.location.origin)
        if (pathname.startsWith('/notes/')) return 'note'
        if (pathname.startsWith('/projects/')) return 'project'
        return 'page'
      } catch {
        return 'page'
      }
    }

    const getResultTypeBadgeHtml = (type) => {
      const fallbackType = 'page'
      const resolvedType = ['note', 'project', 'page'].includes(type)
        ? type
        : fallbackType

      const template = typeTemplatesRoot?.querySelector(
        `[data-search-type="${resolvedType}"]`,
      )

      return template?.outerHTML || ''
    }

    const escapeHtml = (value) =>
      value
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;')

    const renderResults = (items) => {
      if (!resultsRoot) return

      const groupedItems = items.reduce((groups, item) => {
        const existing = groups.get(item.pageUrl)
        if (existing) {
          existing.matches.push(item)
          return groups
        }

        groups.set(item.pageUrl, {
          pageUrl: item.pageUrl,
          pageTitle: item.title,
          type: item.type,
          matches: [item],
        })
        return groups
      }, new Map())

      resultsRoot.innerHTML = Array.from(groupedItems.values())
        .map((group) => {
          if (group.matches.length === 1) {
            const match = group.matches[0]
            const excerpt = match.excerpt
              ? `<p class="text-muted-foreground mt-1 text-sm leading-relaxed">${match.excerpt}...</p>`
              : ''
            const typeBadge = getResultTypeBadgeHtml(group.type)
            const sectionLabel = match.section
              ? `<p class="text-muted-foreground mb-1 text-[11px] font-medium tracking-[0.12em] uppercase">${escapeHtml(match.section)}</p>`
              : ''

            return `
              <li>
                <a
                  href="${match.url}"
                  class="group bg-background/70 hover:bg-muted/40 hover:border-accent/40 hover:shadow-accent/10 block rounded-xl border p-3.5 shadow-xs transition-all duration-200"
                >
                  <div class="mb-1.5 flex items-start justify-between gap-2">
                    <div class="pr-1">
                      ${sectionLabel}
                      <p class="text-foreground text-[15px] leading-snug font-medium">${escapeHtml(match.title)}</p>
                    </div>
                    ${typeBadge}
                  </div>
                  ${excerpt}
                  <p class="text-muted-foreground mt-2 text-xs font-mono tracking-wide uppercase">${escapeHtml(match.url)}</p>
                </a>
              </li>
            `
          }

          const typeBadge = getResultTypeBadgeHtml(group.type)
          const subResults = `<ul class="mt-3 space-y-1.5 border-t pt-3">
              ${group.matches
                .map((match) => {
                  const sectionText = match.section || 'Open page'
                  return `
                    <li>
                      <a
                        href="${match.url}"
                        class="group/subresult hover:bg-muted/60 flex items-start justify-between gap-3 rounded-lg px-2.5 py-2 transition-colors"
                      >
                        <div class="min-w-0">
                          <p class="text-foreground text-sm font-medium leading-snug">${escapeHtml(sectionText)}</p>
                          ${
                            match.excerpt
                              ? `<p class="text-muted-foreground mt-0.5 line-clamp-2 text-xs leading-relaxed">${match.excerpt}...</p>`
                              : ''
                          }
                        </div>
                        <span class="text-muted-foreground group-hover/subresult:text-foreground shrink-0 text-xs transition-colors">#</span>
                      </a>
                    </li>
                  `
                })
                .join('')}
            </ul>`

          return `
            <li>
              <div class="bg-background/70 rounded-xl border p-3.5 shadow-xs">
                <div class="mb-1.5 flex items-start justify-between gap-2">
                  <div class="pr-1">
                    <a
                      href="${group.pageUrl}"
                      class="text-foreground hover:text-accent text-[15px] leading-snug font-medium transition-colors"
                    >
                      ${escapeHtml(group.pageTitle)}
                    </a>
                  </div>
                  ${typeBadge}
                </div>
                <p class="text-muted-foreground mt-2 text-xs font-mono tracking-wide uppercase">${escapeHtml(group.pageUrl)}</p>
                ${subResults}
              </div>
            </li>
          `
        })
        .join('')
    }

    const search = async (query) => {
      if (!query || query.length < 2) {
        clearResults()
        setStatus('Type at least 2 characters.')
        return
      }

      setStatus('Searching...')

      try {
        const pf = await loadPagefind()
        const result = await pf.search(query)

        const detailed = await Promise.all(
          result.results.map(async (item) => {
            const data = await item.data()
            const pageTitle = data.meta?.title || data.url
            const pageType = getResultType(data.url)
            const subResults = (data.sub_results ?? []).map((subResult) => ({
              pageUrl: data.url,
              url: subResult.url || data.url,
              title: pageTitle,
              section: subResult.anchor?.text || '',
              excerpt: subResult.excerpt || data.excerpt || '',
              type: pageType,
            }))

            if (subResults.length > 0) return subResults

            return [
              {
                pageUrl: data.url,
                url: data.url,
                title: pageTitle,
                section: '',
                excerpt: data.excerpt || '',
                type: pageType,
              },
            ]
          }),
        )

        const filtered = detailed
          .flat()
          .filter((item) => !shouldIgnoreResultUrl(item.url))
          .slice(0, 12)

        renderResults(filtered)
        setStatus(
          filtered.length === 0
            ? 'No results found.'
            : `Showing ${filtered.length} result${filtered.length === 1 ? '' : 's'}.`,
        )
      } catch {
        clearResults()
        setStatus('Search is unavailable right now. Build the site to generate the Pagefind index.')
      }
    }

    openButton?.addEventListener('click', openModal)
    closeButton?.addEventListener('click', closeModal)
    backdrop?.addEventListener('click', closeModal)
    modal.addEventListener('click', (event) => {
      if (modal.classList.contains('hidden')) return
      if (!(event.target instanceof Node)) return
      if (panel && !panel.contains(event.target)) {
        closeModal()
      }
    })

    input?.addEventListener('input', (event) => {
      const query = event.target?.value?.trim() || ''
      if (debounceTimer) clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => search(query), 250)
    })

    resultsRoot?.addEventListener('click', (event) => {
      const target = event.target
      if (target instanceof HTMLElement && target.closest('a')) {
        closeModal()
      }
    })

    document.addEventListener('keydown', (event) => {
      const active = document.activeElement
      const isTypingInField =
        active instanceof HTMLInputElement ||
        active instanceof HTMLTextAreaElement ||
        active?.getAttribute('contenteditable') === 'true'

      if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault()
        openModal()
      }

      if (!isTypingInField && event.key === '/') {
        event.preventDefault()
        openModal()
      }

      if (event.key === 'Escape' && !modal.classList.contains('hidden')) {
        event.preventDefault()
        closeModal()
      }
    })
  }

  document.addEventListener('astro:page-load', initSearchModal)
  document.addEventListener('astro:after-swap', initSearchModal)
</script>
