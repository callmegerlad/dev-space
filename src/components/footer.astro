---
import { Separator } from '@/components/ui/separator'
import { SOCIAL_LINKS } from '@/consts'
import Link from './link.astro'
import SocialIcons from './social-icons.astro'
---

<footer
  class="mx-auto mb-8 flex w-full max-w-3xl flex-col items-center justify-center gap-y-2 px-4 sm:mb-4 sm:flex-row sm:justify-between"
>
  <div class="flex flex-wrap items-center justify-center gap-x-2 text-center text-sm">
    <span class="text-muted-foreground">
      &copy; {new Date().getFullYear()} <span class="text-accent font-semibold">Gerald Koh</span>. All rights reserved.
    </span>
    <Separator orientation="vertical" className="hidden h-4! sm:block" />
    <p class="text-muted-foreground">
      Made with ❤️ by <Link
        href="https://github.com/callmegerlad"
        class="text-foreground"
        external
        underline>geraldkjk</Link
      >!
    </p>
  </div>
  <SocialIcons links={SOCIAL_LINKS} />
</footer>
